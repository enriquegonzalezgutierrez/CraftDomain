# Godot-specific ignores
.godot/
*.translation

# Editor-specific ignores
.import/
export_presets.cfg

# Mono/C# specific (if added in the future)
.mono/
data_*/
mono_crash*.log

# System/OS files
.DS_Store
Thumbs.db
*.tmp